# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/jkuat_queue

# Server Port (default: 3000)
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Node Environment
NODE_ENV=development

# ============================================================================
# M-PESA Configuration for Golden Ticket Feature
# ============================================================================

# Sandbox/Production Mode
# Set to 'true' for sandbox testing, 'false' for live payments
MPESA_SANDBOX=true

# M-PESA Consumer Credentials
# Get these from: https://developer.safaricom.co.ke/daraja
# Sandbox: Use your test app credentials
# Production: Use your production app credentials
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# M-PESA Business Details
# Sandbox Business Short Code: 174379
# Production: Your registered shortcode from Safaricom
MPESA_SHORTCODE=174379

# M-PESA Passkey
# Sandbox: bfb279f9ba9b9d1380007480bbe7f27425e1aa6d4ede3891ec337007a74ff42
# Production: Provided by Safaricom when you register
MPESA_PASSKEY=bfb279f9ba9b9d1380007480bbe7f27425e1aa6d4ede3891ec337007a74ff42

# M-PESA Callback URL
# This is where M-PESA sends payment confirmations
# Must be publicly accessible (not localhost)
# Development: Use ngrok, tunnelmole, or similar: https://your-tunnel.ngrok.io/api/queue/mpesa-callback
# Production: Your actual domain: https://jkuat-queue.com/api/queue/mpesa-callback
MPESA_CALLBACK_URL=https://your-domain.com/api/queue/mpesa-callback

# ============================================================================
# Admin Credentials (Change these in production!)
# ============================================================================
ADMIN_USERNAME=Admin0375
ADMIN_PASSWORD=group2sysdev
