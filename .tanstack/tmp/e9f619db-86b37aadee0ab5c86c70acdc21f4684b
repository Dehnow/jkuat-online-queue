import { createFileRoute, useNavigate } from '@tanstack/react-router'
import { useState } from 'react'

export const Route = createFileRoute('/admin')({
  component: LoginPage,
})

function LoginPage() {
  const navigate = useNavigate()
  const [role, setRole] = useState<'student' | 'staff'>('student')
  const [username, setUsername] = useState('')
  const [password, setPassword] = useState('')
  const [error, setError] = useState('')
  const [loading, setLoading] = useState(false)

  const handleLogin = async (e: React.FormEvent) => {
    e.preventDefault()
    if (role === 'student') {
      // No authentication for student – just go to home
      navigate({ to: '/' })
      return
    }

    // Staff/Admin login
    setLoading(true)
    const auth = btoa(`${username}:${password}`)
    try {
      const res = await fetch('/api/admin/report', {
        headers: { Authorization: `Basic ${auth}` }
      })
      if (res.ok) {
        sessionStorage.setItem('adminAuth', auth)
        navigate({ to: '/admin' })
      } else {
        setError('Invalid username or password')
      }
    } catch {
      setError('Network error – try again')
    } finally {
      setLoading(false)
    }
  }

  return (
    <div className="min-h-screen flex items-center justify-center px-4 relative"
         style={{
           backgroundImage: 'url(/background.jpeg)',
           backgroundSize: 'cover',
           backgroundPosition: 'center',
         }}>
      {/* Blurry overlay */}
      <div className="absolute inset-0 backdrop-blur-md bg-black/30"></div>

      <div className="relative z-10 bg-white/20 backdrop-blur-lg rounded-2xl shadow-2xl w-full max-w-md p-8 border border-white/30">
        <div className="flex flex-col items-center mb-6">
          <div className="w-20 h-20 rounded-full overflow-hidden border-4 border-yellow-400 shadow-lg mb-3 bg-white">
            <img src="/queue-bg.jpeg" alt="JKUAT" className="w-full h-full object-cover" />
          </div>
          <h1 className="text-2xl font-bold text-white text-center">JKUAT Queue System</h1>
          <p className="text-sm text-gray-200 mt-1">Select your role to continue</p>
        </div>

        {/* Role Toggle */}
        <div className="flex gap-3 mb-6">
          <button
            onClick={() => setRole('student')}
            className={`flex-1 py-2 rounded-xl font-semibold transition-all ${
              role === 'student'
                ? 'bg-green-600 text-white shadow-lg'
                : 'bg-white/20 text-gray-200 hover:bg-white/30'
            }`}
          >
            🧑‍🎓 Student
          </button>
          <button
            onClick={() => setRole('staff')}
            className={`flex-1 py-2 rounded-xl font-semibold transition-all ${
              role === 'staff'
                ? 'bg-blue-700 text-white shadow-lg'
                : 'bg-white/20 text-gray-200 hover:bg-white/30'
            }`}
          >
            👩‍💼 Staff/Admin
          </button>
        </div>

        <form onSubmit={handleLogin} className="space-y-4">
          {role === 'staff' && (
            <>
              <div>
                <label className="block text-sm font-semibold text-white mb-1">Username</label>
                <input
                  type="text"
                  required
                  value={username}
                  onChange={e => setUsername(e.target.value)}
                  className="w-full rounded-lg px-3 py-2.5 bg-white/90 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                />
              </div>
              <div>
                <label className="block text-sm font-semibold text-white mb-1">Password</label>
                <input
                  type="password"
                  required
                  value={password}
                  onChange={e => setPassword(e.target.value)}
                  className="w-full rounded-lg px-3 py-2.5 bg-white/90 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                />
              </div>
            </>
          )}
          {error && <div className="text-red-200 text-sm bg-red-900/50 p-2 rounded">{error}</div>}
          <button
            type="submit"
            disabled={loading}
            className="w-full py-2.5 rounded-xl font-bold text-white bg-gradient-to-r from-blue-800 to-green-700 hover:scale-[1.02] transition-transform disabled:opacity-50"
          >
            {loading ? 'Logging in...' : role === 'student' ? 'Continue as Student →' : 'Login as Staff'}
          </button>
        </form>
      </div>
    </div>
  )
}